# ─── Supabase ─────────────────────────────────────────────────────────────────
# Create a project at https://supabase.com and paste the values from:
# Dashboard -> Settings -> API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SECRET_KEY=your-service-role-key

# ─── Database (via Supabase) ───────────────────────────────────────────────────
# Dashboard -> Settings -> Database -> Connection string
# DATABASE_URL  = Transaction mode (port 6543) — used at runtime
# DIRECT_URL    = Session mode (port 5432)    — used by prisma migrate
DATABASE_URL=postgresql://postgres.your-ref:password@aws-0-region.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres:password@db.your-ref.supabase.co:5432/postgres

# ─── Authentication ───────────────────────────────────────────────────────────
AUTH_SECRET=your-secret-here-change-in-production-min-32-chars

# ─── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_URL=http://localhost:3000
SITE_TITLE=My NextPress Site

# ─── Initial admin account (used by db:seed) ─────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123

# ─── API service (Express, runs on port 3001) ─────────────────────────────────
API_URL=http://localhost:3001

# ─── Cache revalidation bridge ────────────────────────────────────────────────
# Secret shared between the Express API and Next.js for on-demand revalidation.
# Generate with: openssl rand -base64 32
REVALIDATE_SECRET=your-revalidate-secret-here

# ─── File Storage ─────────────────────────────────────────────────────────────
# STORAGE_DRIVER=supabase    # supabase (default) | s3 | local
SUPABASE_STORAGE_BUCKET=media

# S3-compatible (AWS S3, Cloudflare R2, MinIO) — pnpm add @aws-sdk/client-s3
# STORAGE_DRIVER=s3
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=
# S3_PUBLIC_URL=

# Local filesystem (for self-hosted with persistent volume)
# STORAGE_DRIVER=local
# UPLOAD_DIR=./uploads
# UPLOAD_URL=http://localhost:3000/uploads

# ─── Redis (used by background job queues) ────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Email — Resend (recommended) ─────────────────────────────────────────────
# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@yourdomain.com

# ─── Stripe (optional) ────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
