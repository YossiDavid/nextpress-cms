# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://nextpress:nextpress@localhost:5432/nextpress

# ─── Redis (used by background worker) ────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Authentication ───────────────────────────────────────────────────────────
AUTH_SECRET=your-secret-here-change-in-production-min-32-chars

# ─── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_URL=http://localhost:3000
SITE_TITLE=My NextPress Site

# ─── Initial admin account (used by db:seed) ─────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123

# ─── File Storage (local dev) ─────────────────────────────────────────────────
UPLOAD_DIR=./uploads
UPLOAD_URL=http://localhost:3000/uploads

# ─── File Storage — S3-compatible (production) ────────────────────────────────
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=              # optional: custom endpoint (Cloudflare R2, MinIO, etc.)

# ─── Email — Resend (recommended) ─────────────────────────────────────────────
# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@yourdomain.com

# ─── Email — SMTP (alternative) ───────────────────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=noreply@yourdomain.com

# ─── Stripe (optional) ────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
