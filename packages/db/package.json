{
  "name": "@nextpress/db",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "db:migrate": "dotenv -e ../../.env.local -- prisma migrate dev --skip-generate",
    "db:deploy": "dotenv -e ../../.env.local -- prisma migrate deploy",
    "db:generate": "dotenv -e ../../.env.local -- prisma generate",
    "db:seed": "dotenv -e ../../.env.local -- tsx src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.17.0"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2",
    "prisma": "^5.17.0",
    "tsx": "^4.16.0"
  }
}
