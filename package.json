{
  "name": "nextpress",
  "private": true,
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter @nextpress/web",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "db:migrate": "turbo db:migrate",
    "db:deploy": "pnpm --filter @nextpress/db db:deploy",
    "db:studio": "cd packages/db && pnpm prisma studio",
    "db:seed": "cd packages/db && pnpm tsx src/seed.ts",
    "publish:cli": "pnpm --filter create-nextpress-cms publish --access public --no-git-checks"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  }
}
