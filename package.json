{
  "name": "nextpress",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter @nextpress/web",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "db:migrate": "turbo db:migrate",
    "db:studio": "cd packages/db && pnpm prisma studio",
    "db:seed": "cd packages/db && pnpm tsx src/seed.ts"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  }
}
